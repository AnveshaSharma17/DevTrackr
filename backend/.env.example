PORT=10000
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/devtrackr?retryWrites=true&w=majority
JWT_SECRET=generate_a_long_random_string_here
JWT_EXPIRES_IN=7d
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
# For Render production:
GITHUB_CALLBACK_URL=https://your-render-backend-url.onrender.com/api/github/callback
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MODEL_FALLBACK=gemini-1.5-flash
# For Render production (comma-separated if needed):
FRONTEND_URL=https://your-vercel-app.vercel.app
NODE_ENV=production
